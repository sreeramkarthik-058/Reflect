# These are the client-side env vars (Vite exposes only VITE_-prefixed vars to the browser)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Backend API URL — leave empty for local dev (Vite proxy handles /api/* → localhost:3001)
# Set to your Render backend URL in production, e.g. https://reflect-api.onrender.com
VITE_API_URL=
